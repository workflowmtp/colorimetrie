{
    "name": "colorlab-pro",
    "version": "1.0.0",
    "description": "ColorLab Pro — Gestion colorimetrique industrielle MULTIPRINT S.A.",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "db:generate": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js generate",
        "db:push": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js db push",
        "db:migrate": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js migrate dev",
        "db:seed": "node -r ./prisma/load-env.js node_modules/tsx/dist/cli.mjs prisma/seed.ts",
        "db:studio": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js studio",
        "db:reset": "node -r ./prisma/load-env.js node_modules/prisma/build/index.js migrate reset --force && node -r ./prisma/load-env.js node_modules/tsx/dist/cli.mjs prisma/seed.ts",
        "postinstall": "prisma generate"
    },
    "dependencies": {
        "@prisma/client": "^6.4.0",
        "next": "^15.2.0",
        "next-auth": "^4.24.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zustand": "^5.0.0",
        "bcryptjs": "^2.4.3",
        "dotenv": "^16.4.0",
        "clsx": "^2.1.0",
        "tailwind-merge": "^2.6.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "^22.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "autoprefixer": "^10.4.0",
        "postcss": "^8.4.0",
        "prisma": "^6.4.0",
        "tailwindcss": "^3.4.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}