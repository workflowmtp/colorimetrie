# ================================================================
# COLORLAB PRO — Variables d'environnement
# ================================================================

# PostgreSQL (Variables individuelles comme 5S-nextjs)
DB_HOST="your-db-host.vercel.app"
DB_PORT="5432"
DB_USER="your_username"
DB_PASSWORD="your_password"
DB_NAME="colorlab_pro"

# Alternative: DATABASE_URL direct (si vous préférez)
# DATABASE_URL="postgresql://username:password@host:port/database?schema=public"

# NextAuth (IMPORTANT: générer un secret sécurisé pour la production)
NEXTAUTH_URL="https://colorimetrie.vercel.app"
NEXTAUTH_SECRET="your-super-secret-key-32-chars-minimum"

# Agent IA Configuration
# Option 1: Anthropic API
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Option 2: n8n webhook
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/your-webhook-id"
N8N_WEBHOOK_USER="your-webhook-username"
N8N_WEBHOOK_PASSWORD="your-webhook-password"

# Application
NEXT_PUBLIC_APP_NAME="ColorLab Pro"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_COMPANY="MULTIPRINT S.A."
NEXT_PUBLIC_CURRENCY="FCFA"

# Optionnel: Configuration email pour notifications
# EMAIL_FROM="noreply@your-domain.com"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
