# ============================================================
# COLORLAB PRO — Environment Variables
# ============================================================

# PostgreSQL Database
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASS="postgres"
DB_NAME="colorlab_pro"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production-min-32-chars"

# n8n Webhook (Agent IA)
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/your-webhook-id"
N8N_WEBHOOK_USER="multiprint"
N8N_WEBHOOK_PASS=""

# Application
NEXT_PUBLIC_APP_NAME="ColorLab Pro"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_COMPANY="MULTIPRINT S.A."
NEXT_PUBLIC_CURRENCY="FCFA"
