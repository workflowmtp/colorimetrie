{
    "buildCommand": "npm run build",
    "outputDirectory": ".next",
    "installCommand": "npm install",
    "framework": "nextjs",
    "regions": ["cdg1"],
    "functions": {
        "src/app/api/**/*.ts": {
            "maxDuration": 30
        }
    },
    "crons": [{
        "path": "/api/cron/backup",
        "schedule": "0 2 * * *"
    }]
}